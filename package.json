{
  "name": "bhekani.com",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "lint": "astro check",
    "generate:search-index": "bun run scripts/generate-search-index.ts",
    "generate:embeddings": "bun run scripts/generate-embeddings.ts",
    "prebuild": "bun run generate:search-index && bun run generate:embeddings",
    "build": "bun run lint && astro sync && astro build --remote",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "husky",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
